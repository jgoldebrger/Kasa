# --- Database ---
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.net/kasa?retryWrites=true&w=majority

# --- Auth (NextAuth) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# --- At-rest encryption ---
ENCRYPTION_KEY=

# --- Cron (Vercel Cron + scripts/*) ---
# REQUIRED in production. All `/api/jobs/*` routes reject requests without a
# valid secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Send as `x-cron-secret: <value>` or `Authorization: Bearer <value>`.
# Set the same value in Vercel env vars; Vercel Cron sends Bearer automatically.
# KASA defines five crons in vercel.json — Vercel Pro is required for >2 jobs.
CRON_SECRET=

# --- Platform admins ---
PLATFORM_ADMIN_EMAILS=

# --- Platform SMTP (system mail) ---
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASS=
PLATFORM_SMTP_FROM=

# --- Stripe (optional) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform subscription price IDs (Stripe Dashboard → Products)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_COMMUNITY=
STRIPE_PRICE_INSTITUTION=

# --- Observability (recommended for production) ---
# Sentry captures API errors (lib/log), React error boundaries, and Web Vitals.
# Create a project at https://sentry.io — use the same DSN for both vars unless
# you split server/client projects. Leave blank for local dev.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- Operational ---
TRUST_PROXY_HEADERS=false

# --- Rate limiting (optional) ---
# When set, rate limits use Upstash Redis instead of MongoDB writes per API hit.
# Create a free database at https://console.upstash.com — omit both to use Mongo.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# --- Security testing (Playwright + ZAP) ---
# SECURITY_ENV=local
# SECURITY_TARGET_URL=http://127.0.0.1:3000
# SECURITY_OWNER_EMAIL=e2e@kasa.test
# SECURITY_OWNER_PASSWORD=
# SECURITY_MEMBER_EMAIL=e2e-member@kasa.test
# SECURITY_MEMBER_PASSWORD=E2eMemberPass123!
# SECURITY_ORG_ALPHA=E2E Org Alpha
# SECURITY_ORG_BETA=E2E Org Beta
# SECURITY_ALLOW_DESTRUCTIVE=true
# SECURITY_PROXY_ENABLED=false
# SECURITY_PROXY_URL=http://127.0.0.1:8080
# SECURITY_PROXY_IGNORE_TLS_ERRORS=true
# SECURITY_ZAP_ENABLED=false
# SECURITY_ZAP_API_URL=http://127.0.0.1:8080
# SECURITY_REPORT_DIR=security/reports/output
