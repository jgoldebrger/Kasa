# KASA environment variables
# Copy to `.env.local` for local dev. For Vercel: Project → Settings → Environment
# Variables — add each name/value, then redeploy.
#
# Validate production secrets locally: npm run check:env

# =============================================================================
# Database (REQUIRED in production)
# =============================================================================
MONGODB_URI=mongodb+srv://USER:PASS@cluster.example.net/kasa?retryWrites=true&w=majority
# Optional. Overrides lib/database.ts pool defaults (prod 30, dev 10).
# MONGODB_MAX_POOL_SIZE=30

# =============================================================================
# Auth — NextAuth (REQUIRED in production)
# =============================================================================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=
# Must match NEXTAUTH_SECRET (NextAuth v5 alias).
AUTH_SECRET=
# Public app URL — use https://your-app.vercel.app in production.
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# At-rest encryption (REQUIRED in production)
# =============================================================================
# Encrypts org SMTP passwords, 2FA secrets, etc. Use a dedicated key — not NEXTAUTH_SECRET.
ENCRYPTION_KEY=
# After migrating legacy plaintext 2FA secrets, set true to reject unencrypted rows.
# REJECT_LEGACY_PLAINTEXT_2FA=true

# =============================================================================
# Cron (REQUIRED in production)
# =============================================================================
# All `/api/jobs/*` routes reject requests without a valid secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Send as `x-cron-secret: <value>` or `Authorization: Bearer <value>`.
# Set the same value in Vercel; Vercel Cron sends Bearer automatically.
# KASA defines five crons in vercel.json — Vercel Pro is required for >2 jobs.
CRON_SECRET=

# =============================================================================
# Platform admins
# =============================================================================
# Comma-separated emails — notified on invite requests; can review at /admin/invite-requests.
PLATFORM_ADMIN_EMAILS=

# =============================================================================
# Platform SMTP (system mail — password resets, invite alerts)
# =============================================================================
PLATFORM_SMTP_HOST=
PLATFORM_SMTP_PORT=587
PLATFORM_SMTP_USER=
PLATFORM_SMTP_PASS=
PLATFORM_SMTP_FROM=
# Set to false for STARTTLS on port 587 (default true = implicit TLS on 465).
# PLATFORM_SMTP_SECURE=false

# =============================================================================
# Stripe — member card payments + platform subscriptions (optional)
# =============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Platform subscription price IDs (Stripe Dashboard → Products).
# Billing gates (family caps, member charges) activate when STRIPE_SECRET_KEY
# and STRIPE_PRICE_STARTER are both set.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_COMMUNITY=
STRIPE_PRICE_INSTITUTION=
# When true, member card charges route through each org's Stripe Connect Express
# account; funds settle to the org's bank. When false/unset, charges go to the
# platform Stripe account. See docs/STRIPE_MONEY_FLOW.md.
STRIPE_CONNECT_ENABLED=false

# =============================================================================
# Observability (recommended for production)
# =============================================================================
# Sentry — API errors, React boundaries, Web Vitals. https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.05
# NEXT_PUBLIC_SENTRY_REPLAY_ON_ERROR_RATE=0.1

# =============================================================================
# Operational
# =============================================================================
# Trust X-Forwarded-For / X-Real-IP for rate limiting. On Vercel this is
# automatic (VERCEL=1 is set by the platform); set true for other proxies.
TRUST_PROXY_HEADERS=false
# Canonical public URL override (Stripe Connect return URLs, billing checkout).
# Falls back to NEXTAUTH_URL, then http://localhost:3000.
# APP_BASE_URL=https://your-app.vercel.app
# Server log level: trace | debug | info | warn | error | fatal | silent
# LOG_LEVEL=info
# Tighter search rate limit in security/CI runs (20/min vs 60/min).
# SECURITY_STRICT_RATE_LIMITS=1

# =============================================================================
# Rate limiting (recommended for production)
# =============================================================================
# When both are set, rate limits use Upstash Redis instead of MongoDB writes.
# https://console.upstash.com — omit both to fall back to Mongo.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Scripts & one-off ops (not needed for normal Vercel runtime)
# =============================================================================
# scripts/send-monthly-statements.js
# API_URL=http://localhost:3000
# scripts/generate-monthly-statements.ts — target a single org
# ORGANIZATION_ID=
# scripts/migrate-to-multi-tenant.js — legacy DB migration
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# ADMIN_NAME=Admin

# =============================================================================
# Integration / E2E tests (Vitest, Playwright — not for production)
# =============================================================================
# KASA_TEST_DB_NAME=
# KASA_TEST_STRIPE_ORG=
# KASA_TEST_STRIPE_FAMILY=
# E2E_PORT=3000
# E2E_BULK_FAMILIES=0

# =============================================================================
# Security testing (Playwright + ZAP) — see security/README.md
# =============================================================================
# SECURITY_ENV=local
# SECURITY_TARGET_URL=http://127.0.0.1:3000
# SECURITY_STAGING_URL=
# SECURITY_PROD_LIKE_URL=
# SECURITY_OWNER_EMAIL=e2e@kasa.test
# SECURITY_OWNER_PASSWORD=
# SECURITY_OWNER_NAME=E2E Test User
# SECURITY_MEMBER_EMAIL=e2e-member@kasa.test
# SECURITY_MEMBER_PASSWORD=E2eMemberPass123!
# SECURITY_MEMBER_NAME=E2E Member User
# SECURITY_PLATFORM_ADMIN_EMAIL=
# SECURITY_PLATFORM_ADMIN_PASSWORD=
# SECURITY_ORG_ALPHA=E2E Org Alpha
# SECURITY_ORG_BETA=E2E Org Beta
# SECURITY_ALLOW_DESTRUCTIVE=true
# SECURITY_PROXY_ENABLED=false
# SECURITY_PROXY_URL=http://127.0.0.1:8080
# SECURITY_PROXY_USERNAME=
# SECURITY_PROXY_PASSWORD=
# SECURITY_PROXY_IGNORE_TLS_ERRORS=true
# SECURITY_ZAP_ENABLED=false
# SECURITY_ZAP_API_URL=http://127.0.0.1:8080
# SECURITY_ZAP_API_KEY=
# SECURITY_ZAP_DOCKER_IMAGE=ghcr.io/zaproxy/zaproxy:stable
# SECURITY_ZAP_TIMEOUT_MS=600000
# SECURITY_ZAP_FULL_MINS=15
# SECURITY_REPORT_DIR=security/reports/output
# SECURITY_CAPTURE_HAR=true
# SECURITY_CAPTURE_TRAFFIC=true
# SECURITY_RATE_LIMIT_WORKERS=10
# SECURITY_RATE_LIMIT_BURST=30
# SECURITY_ORG_HEADER=x-organization-id
# SECURITY_CRON_SECRET=
