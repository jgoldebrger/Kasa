{
  "name": "kasa-family-management",
  "version": "1.0.0",
  "description": "Kasa Family Financial Management System - Age-based payment and lifecycle event tracking",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 --turbo",
    "dev:webpack": "next dev -p 3000",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:coverage:report": "vitest run --coverage",
    "test:all:coverage": "vitest run --coverage && playwright test",
    "test:watch": "vitest",
    "test:api-routes": "vitest run --project=api-routes",
    "test:route-logic-coverage": "vitest run --config vitest.route-logic.config.ts --coverage",
    "test:route-logic-coverage:report": "vitest run --config vitest.route-logic.config.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:forms": "playwright test e2e/features/form-persistence",
    "test:e2e:large-org": "npx --yes cross-env@7.0.3 E2E_BULK_FAMILIES=1100 playwright test e2e/large-org.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "security:test": "npx tsx scripts/security-run.ts",
    "security:test:ui": "npx tsx scripts/security-run.ts --ui",
    "security:test:guest": "npx tsx scripts/security-run.ts --guest",
    "security:test:safe": "npx tsx scripts/security-run.ts --safe",
    "security:zap:up": "npx tsx scripts/security-zap.ts up",
    "security:zap:baseline": "npx tsx scripts/security-zap.ts baseline",
    "security:zap:full": "npx tsx scripts/security-zap.ts full",
    "security:zap:down": "npx tsx scripts/security-zap.ts down",
    "security:sast": "echo Run CodeQL and Semgrep via GitHub Actions, or: semgrep scan --config .semgrep.yml",
    "security:catalog:generate": "npx tsx scripts/generate-api-route-inventory.ts",
    "api-handlers:extract": "npx tsx scripts/extract-api-route-handlers.ts",
    "route-logic:extract": "npx tsx scripts/extract-handler-logic-to-lib.ts",
    "app-smoke:generate": "npx tsx scripts/generate-app-smoke-tests.ts",
    "test:all": "vitest run && playwright test",
    "test:full": "vitest run && playwright test",
    "typecheck": "tsc --noEmit",
    "prepare": "simple-git-hooks",
    "generate-statements": "npx tsx scripts/generate-monthly-statements.ts",
    "send-monthly-statements": "node scripts/send-monthly-statements.js",
    "process-monthly-payments": "node scripts/process-monthly-payments.js"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js}": [
      "prettier --write",
      "next lint --file"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "//peer-deps": "Auth.js v5 has no stable npm release (latest tag is 4.x). next-auth pinned to 5.0.0-beta.31; nodemailer@7.0.10 satisfies next-auth/@auth/core optional peer ^7.0.7. npm ci works without --legacy-peer-deps.",
  "dependencies": {
    "@hebcal/core": "^6.0.5",
    "@heroicons/react": "^2.2.0",
    "@sentry/nextjs": "^10.53.1",
    "@stripe/react-stripe-js": "^5.3.0",
    "@stripe/stripe-js": "^8.3.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "mongoose": "^7.5.0",
    "next": "^15.5.19",
    "next-auth": "5.0.0-beta.31",
    "nodemailer": "7.0.13",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "stripe": "^19.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.5.19",
    "@playwright/test": "^1.60.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.24",
    "@types/nodemailer": "^7.0.3",
    "@types/react": "^18.3.26",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.10.31",
    "caniuse-lite": "^1.0.30001793",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.19",
    "happy-dom": "^20.9.0",
    "lint-staged": "^17.0.5",
    "mongodb-memory-server": "^11.1.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.3",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "exceljs": {
      "uuid": "^11.1.1"
    }
  }
}
